# Google Analytics 4 property ID (numeric, found in GA4 Admin > Property Settings)
# Find this in GA4 Admin > Property Settings > Property ID
GA4_PROPERTY_ID=YOUR_GA4_PROPERTY_ID_HERE

# Google Search Console property URL (include protocol)
SEARCH_CONSOLE_PROPERTY=https://www.freemindconsultancy.com

# Path to Google Cloud service account JSON key
SERVICE_ACCOUNT_FILE=credentials/service-account.json

# Path to your website source files (for local modifications)
WEBSITE_ROOT=D:/Free Mind Website/freemind-website
